BOT_TOKEN=put_status_bot_token_here
ADMIN_IDS=123456789
BOT_TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO
CHECK_INTERVAL_SECONDS=7200
SUMMARY_INTERVAL_SECONDS=7200
SEND_PERIODIC_SUMMARY=true
SUMMARY_ON_STARTUP=true
ALERT_COOLDOWN_SECONDS=600
ALERT_FAILURE_CONFIRMATIONS=2
QUIET_HOURS_ENABLED=false
QUIET_HOURS_START=23
QUIET_HOURS_END=8
STATUS_DB_PATH=data/status_bot.db

REMEMBERME_ENABLED=true
REMEMBERME_NAME=RememberMe
REMEMBERME_API_BASE_URL=http://127.0.0.1:8000
REMEMBERME_ADMIN_TOKEN=put_rememberme_admin_token_here
REMEMBERME_TIMEOUT_SECONDS=5
REMEMBERME_REQUIRED=true
REMEMBERME_DOCKER_CONTAINERS=rememberme_bot-api,rememberme_bot-bot,rememberme_bot-worker,rememberme_bot-postgres

INCUBATOR_ENABLED=true
INCUBATOR_NAME=Инкубатор
INCUBATOR_PROJECT_PATH=D:\проекты qwen\tg_bot_inkubator
INCUBATOR_DATABASE_PATH=D:\проекты qwen\tg_bot_inkubator\data\incubator_dev.db
INCUBATOR_PID_FILE=D:\проекты qwen\tg_bot_inkubator\bot.pid
INCUBATOR_REQUIRED=true
INCUBATOR_DOCKER_CONTAINER=
INCUBATOR_SYSTEMD_UNIT=tg-bot-inkubator.service

SERVER_DISK_PATHS=.
SERVER_CPU_WARN_PERCENT=90
SERVER_RAM_WARN_PERCENT=85
SERVER_DISK_WARN_PERCENT=85
TELEGRAM_API_CHECK_ENABLED=true
TELEGRAM_API_TIMEOUT_SECONDS=5
BACKUP_PATHS=/external/backups/rememberme,/external/backups/incubator
LOG_PATHS=/external/logs/rememberme,/external/logs/incubator,/app/logs
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_CHECK_ENABLED=false
SYSTEMD_CHECK_ENABLED=false
